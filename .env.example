# ========================================
# Brew Guide Docker 环境配置示例
# 复制为 .env 后修改
# ========================================

# ------------------ 端口配置 ------------------
# 前端访问端口 (默认 3000)
FRONTEND_PORT=3000

# API 后端端口 (默认 3001)
BACKEND_PORT=3001

# ------------------ 数据存储 ------------------
# SQLite 数据目录 (绝对路径或相对路径)
DATA_PATH=./data

# 备份目录
BACKUP_PATH=./backups

# ------------------ 安全设置 ------------------
# API 访问密钥 (可选，留空表示不启用)
# API_KEY=your-secret-key-here

# 允许的跨域来源，逗号分隔或 * 表示允许全部
# 生产环境建议指定具体域名
CORS_ORIGINS=*

# ------------------ 日志配置 ------------------
# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# ------------------ 备份配置 ------------------
# 启用自动备份
BACKUP_ENABLED=true

# 备份定时 (cron 表达式)，默认每天凌晨 2 点
BACKUP_CRON=0 2 * * *

# 备份保留天数
BACKUP_RETENTION_DAYS=7
